# Mangarr environment template.
#
# Copy this file to `.env` (which is gitignored) and fill in your own
# values. Environment variables provide startup defaults. Values stored
# in the settings table take precedence after the first save.
#
# Deployment guidance: see docs/deployment.md.

# ── Download-client credentials ────────────────────────────────────
# qBittorrent password (paired with QBIT_HOST + QBIT_USER in compose)
QBIT_PASS=change-me

# SABnzbd API key (NOT a password — long random string from SAB's UI)
SAB_APIKEY=change-me

# Prowlarr API key (long random string from Prowlarr's Settings → General)
PROWLARR_KEY=change-me

# ── Optional overrides ─────────────────────────────────────────────
# Uncomment and adjust any setting whose env-var is declared in
# main.py:ENV_DEFAULTS. Common ones:
#
# Secret-at-rest master key. If unset, Mangarr loads
# /config/.mangarr-secret-key or auto-generates that file on first
# boot. Back up the DB and key together. Key rotation is not yet
# supported.
# MANGARR_SECRET_KEY=replace-with-44-char-urlsafe-base64-fernet-key
#
# MANGA_SAVE_PATH=/data/media/manga
# MANGARR_INSTANCE_NAME=Mangarr
# MANGARR_LOG_LEVEL=INFO
# MANGARR_URL_BASE=/mangarr
# MANGA_CATEGORY=manga
# RSS_INTERVAL=900
#
# Standard outbound HTTP proxy variables. Use only when your network requires
# outbound requests to indexers/metadata providers to traverse a proxy.
# HTTP_PROXY=http://proxy.example:8080
# HTTPS_PROXY=http://proxy.example:8080
# NO_PROXY=localhost,127.0.0.1,prowlarr,qbittorrent,sabnzbd,komga
#
# KOMGA_URL=http://komga:25600
# KOMGA_USER=mangarr
# KOMGA_PASS=change-me
# KOMGA_LIBRARY_ID=01234567890
