# Mangarr environment template.
#
# Copy this file to `.env` (which is gitignored) and fill in your own
# values. All of these override any value stored in the settings table
# at startup via load_config — env wins over DB.
#
# Deployment guidance: see docs/deployment.md.

# ── Download-client credentials ────────────────────────────────────
# qBittorrent password (paired with QBIT_HOST + QBIT_USER in compose)
QBIT_PASS=change-me

# SABnzbd API key (NOT a password — long random string from SAB's UI)
SAB_APIKEY=change-me

# Prowlarr API key (long random string from Prowlarr's Settings → General)
PROWLARR_KEY=change-me

# ── Optional overrides ─────────────────────────────────────────────
# Uncomment and adjust any setting whose env-var is declared in
# main.py:ENV_DEFAULTS. Common ones:
#
# MANGA_SAVE_PATH=/data/media/manga
# MANGA_CATEGORY=manga
# RSS_INTERVAL=900
# KOMGA_URL=http://komga:25600
# KOMGA_USER=mangarr
# KOMGA_PASS=change-me
# KOMGA_LIBRARY_ID=01234567890
