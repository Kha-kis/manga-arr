# Mangarr Compose overrides. All values are optional; docker-compose.yml
# provides the defaults shown here. Copy this file to .env only when you
# need to change them.

# Container image and host exposure
MANGARR_VERSION=1.0.0
MANGARR_BIND_ADDRESS=127.0.0.1
MANGARR_PORT=6789

# The container runs without root. Set these to the owner of the host bind
# directories when that user is not UID/GID 1000 (`id -u` / `id -g`).
MANGARR_UID=1000
MANGARR_GID=1000

# Host-visible bind mounts. Keep config and data backed up.
MANGARR_CONFIG_PATH=./config
MANGARR_DATA_PATH=./data

# First-boot application defaults. Settings saved in the UI take precedence.
TZ=UTC
MANGARR_INSTANCE_NAME=Mangarr
MANGARR_LOG_LEVEL=INFO
MANGARR_URL_BASE=
MANGA_SAVE_PATH=/data/media/manga
MANGA_TORRENT_PATH=/data/torrents/manga
MANGA_CATEGORY=manga
RSS_INTERVAL=900

# Optional standard outbound proxy variables. Uncomment only when needed.
# HTTP_PROXY=http://proxy.example:8080
# HTTPS_PROXY=http://proxy.example:8080
# NO_PROXY=localhost,127.0.0.1,prowlarr,qbittorrent,sabnzbd,komga

# Configure indexers, download clients, notifications, Komga, and API access
# in Mangarr's Settings UI. Do not put those credentials in this file.
